# ------------------------------------------------------------------
# Eduspark backend configuration — copy to .env and fill in values
# ------------------------------------------------------------------
PORT=5000
JWT_SECRET=change_me_to_a_long_random_string

# Google sign-in (https://console.cloud.google.com -> Credentials -> OAuth client ID, type "Web application")
# Use the SAME client id in frontend/.env.local as NEXT_PUBLIC_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Razorpay (https://dashboard.razorpay.com -> Settings -> API Keys)
# Leave empty to use the built-in demo checkout (no real money).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Supabase (optional). Leave empty to use local SQLite.
# Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# e.g. postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres
# Tables are created and seeded automatically on first boot; supabase-schema.sql
# is also provided if you prefer running it in the Supabase SQL editor.
SUPABASE_DB_URL=
